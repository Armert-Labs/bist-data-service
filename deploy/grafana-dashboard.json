{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "BIST Data Service",
  "uid": "bist-data-service",
  "tags": ["bist", "finance"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Onbellekteki Sembol",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "bist_quotes_cached", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Son Guncelleme Yasi (sn)",
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [
        { "color": "green", "value": null }, { "color": "red", "value": 300 } ] } } },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "bist_last_update_age_seconds", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Kaynaklar Arasi Sapma (%)",
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [
        { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "bist_cross_source_drift_pct", "refId": "A" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Aktif SSE Baglantilari",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "bist_sse_clients", "refId": "A" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Guncelleme Turu Suresi (p50/p95)",
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.5, rate(bist_update_duration_seconds_bucket[5m]))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(bist_update_duration_seconds_bucket[5m]))", "legendFormat": "p95", "refId": "B" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Kaynak Sagligi (1=up)",
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "min": 0, "max": 1 } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [{ "expr": "bist_provider_up", "legendFormat": "{{provider}}", "refId": "A" }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP Istek Hizi (req/s)",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [{ "expr": "sum(rate(http_requests_total[5m])) by (handler)", "legendFormat": "{{handler}}", "refId": "A" }]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Kaynak Cekim Hatalari (rate)",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [{ "expr": "sum(rate(bist_fetch_errors_total[5m])) by (provider)", "legendFormat": "{{provider}}", "refId": "A" }]
    }
  ]
}
