# --- bist-canli-api ornek ortam degiskenleri ---
# Kullanmak icin: cp .env.example .env

# === Guncelleme / cekim ===
UPDATE_INTERVAL=60          # arka plan guncelleme araligi (sn)
BATCH_SIZE=40               # Yahoo istegi basina sembol sayisi
BATCH_PAUSE=1.0             # batch'ler arasi bekleme (sn)
# piyasa kapaliyken de cek:
UPDATE_WHEN_CLOSED=false
MAX_CONCURRENT_FETCH=8      # es zamanli on-demand cekim ust siniri (thread-pool korumasi)
UPDATER_CYCLE_TIMEOUT=240   # tur zaman butcesi (sn; 0=kapali; STALENESS_SECONDS'tan kucuk tutun)

# === Kaynak / dogrulama ===
# yahoo (yfinance) varsayilan zincirden CIKARILDI: crumb/cookie auth istegi
# (curl_cffi) bazen sonsuza kadar asilip thread havuzunu doldurabiliyor. Provider
# silinmedi; env ile geri eklenebilir: PROVIDERS=yahoo,yahoo_chart,tradingview,isyatirim
# tradingview de PATRON KARARIYLA (hukuki) varsayilan zincirden CIKARILDI:
# TradingView Kullanim Sartlari §3 veriyi yalnizca ekranda-gosterim ile
# sinirlar, otomatik islem/algoritmik karar-verme/fiyat referanslama YASAKTIR
# (bkz. app/providers/tradingview.py ust dosya uyarisi). Env ile geri
# eklenebilir ANCAK YALNIZCA insan-okur dashboard/teshis amaciyla -- bot karar
# yoluna BAGLANMAMALIDIR.
# oncelik sirasi (fallback zinciri):
PROVIDERS=yahoo_chart,isyatirim
# failover | gapfill | hybrid:
PROVIDER_MODE=gapfill
PROVIDER_MIN_COVERAGE_PCT=95            # altinda kalan yanit basarisiz sayilir
PROVIDER_FETCH_TIMEOUT=45               # tek provider.fetch_quotes() cagrisi icin sert ust sinir (sn)
SYMBOL_CIRCUIT_FAIL_THRESHOLD=3
SYMBOL_CIRCUIT_RESET_SECONDS=300
# Bir kaynak ardisik N TUR (batch degil -- bir tur ~13 batch cagrisi uretir,
# bkz. begin_cycle/end_cycle) TAMAMEN bayat-bar/damgasiz guard'iyla duserse
# (sembol devre kesici bunu saymaz -- bilincli tasarim) provider-seviyesinde
# gecici cooldown'a alinabilir. Yalniz updater'in yapilandirilmis dongusu bu
# sayaca katkida bulunur -- on-demand istekler asla cooldown tetiklemez.
# ONEMLI: cooldown yalniz >=2 intraday-capable kaynak varsa fiilen UYGULANIR
# -- TradingView cikarildi + isyatirim EOD-only oldugu icin varsayilan
# yapilandirmada seans icinde TEK intraday kaynak (yahoo_chart) kalmistir;
# tek kaynagi susturmak feed'i kendi kendine keserdi (bkz. app/aggregator.py
# _apply_cycle_guard_result). Fiilen uygulandiginda bile half-open davranir:
# cooldown suresince tur basina 1 "prob" denemesi yapilir, basarili olursa
# cooldown aninda kalkar.
GUARD_COOLDOWN_FAIL_THRESHOLD=3
GUARD_COOLDOWN_SECONDS=1800
# Seans acilisindan sonraki bu kadar saniye icindeki guard-dususleri sayaca
# YAZILMAZ (kaynaklar acilisin ilk saniyelerinde henuz dunku barlarini
# guncellemiyor olabilir -- yapisal gecikme, kalici ariza degil). 1200sn
# (20 dk) = ~15 dk veri gecikmesi + tampon (bkz. delayed=true). Bu pencerede
# fail-open tetiklense bile GUARD_FAIL_OPEN_TOTAL sayaci/CRITICAL log
# BASILMAZ (rutin acilis, alarm degil); store.is_stale() (/ready) de AYNI
# pencereyi kullanir (HIGH-1 review-4: eskiden STALENESS_SECONDS'a bagliydi,
# veri gecikmesinden kisa oldugu icin HER ISLEM GUNU acilista yanlis 503
# uretiyordu).
# KISIT (LOW, review-5): bu deger KAYNAGIN GERCEK VERI GECIKMESINDEN (su an
# ~900 sn / ~15 dk) BUYUK OLMALIDIR -- aksi halde HER ISLEM GUNU acilista
# yanlis CRITICAL + 503 GERI DONER (tam da bu ayarin cozdugu regresyon).
# Kaynak (Yahoo) gecikmesi bir gun 20 dk'yi asarsa bu deger orantili
# BUYUTULMELIDIR (wedge dedektoru -- asagidaki UPDATE_INTERVAL tabanli kontrol
# -- ayri calisir, bu ayardan ETKILENMEZ).
GUARD_OPEN_GRACE_SECONDS=1200
# Son artistan bu kadar saniye sonra hala yeni bir tam-dusme olmadiysa sayac
# GECERSIZ sayilir (yaslanma) -- sabah erken saatte birikmis bir sayac
# saatlerce durup ogleden sonraki TEK kotu turla cooldown'a donusmesin.
GUARD_DROP_STREAK_MAX_AGE_SECONDS=900
# Bir TURDE (updater'in tam guncelleme dongusu -- batch DEGIL, bkz.
# begin_cycle/end_cycle) HICBIR sembol taze quote almazsa VE guard'in
# dusurdugu aday sayisi bu esigi asarsa fail-open tetiklenir -- KAYNAK
# SAYISINA degil CYCLE'in TOPLAM boyutuna bagli esik (tek intraday kaynakli
# dunyada "en az 2 kaynak" sarti hic saglanamazdi). Yalniz updater'in
# yapilandirilmis dongusu (count_toward_cooldown) bu degerlendirmeye girer --
# on-demand istekler (/quotes?symbols=) begin_cycle() hic cagirmadigi icin
# fail-open'i ASLA tetiklemez.
GUARD_FAIL_OPEN_MIN_SYMBOLS=20
SANITY_MAX_CHANGE_PCT=60                # bir onceki fiyata gore absurt sicramalari ele (%)
SANITY_REJECT_ESCAPE_SECONDS=900        # kesintisiz red penceresi + >=2 BAGIMSIZ kaynak uzlasirsa kabul et (Faz-2; tek kaynakli dunyada hic tetiklenmez; 0=kapali)
# Tek intraday kaynakli dunyada (yukaridaki coklu-kaynak uzlasisi YAPISAL
# OLARAK asla tetiklenemez) escape'in TEK canli yolu: ayni kaynak ayni
# (tolerans icindeki) aykiri fiyati bu kadar ARDISIK TURDA (fetch_quotes
# cagrisi basina bir kez, provider basina degil) tekrarlarsa kabul edilir --
# bedelsiz/split sonrasi kalici sanity-kilidini kirar. 0=kapali.
SANITY_ESCAPE_PERSIST_ROUNDS=3
SANITY_ESCAPE_PERSIST_TOLERANCE_PCT=1.0 # "ayni fiyat" sayilmasi icin ardisik turlar arasi izin verilen sapma (%)
# tradingview ToS geregi cikarildi (yukariya bakin) -- seans icinde bagimsiz
# referans kalmadigi icin dogrulama fail-quiet doner (bilinen/kabul edilen
# acik madde, bkz. README/CHANGELOG).
# dogrulama referanslari (kendi kaynagi yapisal olarak dislanir -- en az 2 kaynak sart):
VALIDATE_PROVIDERS=yahoo_chart,isyatirim
WRITE_CROSS_VALIDATE=true
WRITE_CROSS_VALIDATE_ON_DEMAND=true
CROSS_VALIDATE_MAX_PCT=1.0
DRIFT_MONITOR_ENABLED=true
DRIFT_MONITOR_EVERY_N_CYCLES=5
HISTORY_CACHE_TTL=600

# === Sembol evreni (takip listesi) ===
# Statik BIST listesine EK semboller (virgulle). Statik liste her zaman taban kalir.
EXTRA_SYMBOLS=
# Updater dongu basinda TradingView'den tum BIST evrenini cekip listeyi genisletir
# (2026+ yeni hisseler otomatik gorunur). Kayipsiz: statik + extra + evren birlesimi.
# KABUL EDILEN KALINTI RISK (MEDIUM-3, PATRON KARARI: KALSIN -- ucretsiz,
# calisiyor): fiyat zinciri TradingView'den tamamen arindirildi (yukariya
# bakin) ama SEMBOL EVRENI (takip listesi/dizin) hala TradingView'den gelir.
# Bu, fiyat REFERANSLAMA/otomatik-islem degil yalnizca "hangi semboller var"
# bilgisi oldugu icin ToS §3'un yasakladigi kullanimin disinda kalir --
# bilincli bir karar, kod degisikligi planlanmiyor.
SYMBOL_UNIVERSE_REFRESH_ENABLED=true
SYMBOL_UNIVERSE_REFRESH_HOURS=24        # yenileme sikligi (ilk turda + her N saatte bir)
SYMBOL_UNIVERSE_MIN_COUNT=400           # cekilen evren bundan azsa yok sayilir (guard)

# === Is Yatirim erisim ayarlari ===
# Is Yatirim, TR disi IP'lerden erisimi engelleyebilir (TCP timeout). TR cikisli
# bir proxy verilirse Is Yatirim istekleri oradan gecer (Yahoo dogrudan kalir).
# Ornek: ISYATIRIM_PROXY=http://kullanici:sifre@tr-proxy-host:8080
ISYATIRIM_PROXY=
ISYATIRIM_TIMEOUT=10.0
ISYATIRIM_RETRIES=2
ISYATIRIM_CONCURRENCY=5

# === Bayatlik ===
# MARKET ACIKKEN onbellek bu kadar sure guncellenmezse /ready fail + is_stale=true.
# Market kapaliyken veri bayatlamaz (son seans fiyati gecerlidir).
# HIGH-1 (review-4, REGRESYON): acilis toleransi bu degeri DEGIL
# GUARD_OPEN_GRACE_SECONDS'i kullanir (bkz. asagisi) -- veri ~15 dk (900 sn)
# gecikmeli oldugu icin acilisin ilk ~15 dk'sinda TUM sembollerin guard'la
# dusup fail-open'a girmesi rutin/beklenendir; STALENESS_SECONDS (300 sn) ile
# hizalanirsa HER ISLEM GUNU acilista /ready 503 + critical alarm uretirdi.
STALENESS_SECONDS=300
STALENESS_MIN_FRESH_PCT=90  # taze sembol orani bunun altina duserse /ready fail (tek sembol zehirlemez)
NEGATIVE_CACHE_TTL=60       # bulunamayan semboller icin negatif onbellek (sn)

# === Piyasa takvimi ===
# Resmi tatiller (virgulle ayrilmis ISO tarihler). Bu gunlerde market kapali sayilir.
# Bos birakilirsa gomulu varsayilan takvim kullanilir (2026 tam + 2027 ulusal).
# Deger verilirse listeyi TAMAMEN degistirir; "none" tum tatilleri kapatir.
# Ornek: MARKET_HOLIDAYS=2026-10-29,2027-01-01
MARKET_HOLIDAYS=

# === Redis (bos ise in-memory store; tek instance icin yeterli) ===
# Docker Compose'da: redis://redis:6379/0
# Uretimde sifre + TLS: rediss://:SIFRE@redis:6380/0
REDIS_URL=
REDIS_PREFIX=bist

# === Guvenlik / kimlik dogrulama ===
# UYARI: bu bolumdeki hicbir satirda satir-ici (inline) yorum kullanmayin --
# env_file loader'i (Docker Compose native .env parser, tirnaksiz degerlerde)
# "#" sonrasini DEGERE KATAR. Bu, sabit/bilinen bir string'in gecerli API
# anahtari sayilmasina (auth bypass) VEYA bool alanlarda (_get_bool tam-eslesme
# yapar) beklenmedik false'a dusmesine (orn. AUTH_REQUIRED fail-safe yerine
# fail-open) yol acabilir. Yorumlar HER ZAMAN ayri satirda tutulmali.
#
# Coklu anahtar (onerilen): "anahtar:etiket" ciftleri, virgulle.
# Anahtar uret: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ornek: k_abc123:mobil,k_def456:web
API_KEYS=
# Uretimde plaintext yerine hash saklayin (opsiyonel):
# hash al: python -c "import hashlib,sys; print(hashlib.sha256(sys.argv[1].encode()).hexdigest())" <KEY>
API_KEYS_SHA256=
# (geriye uyum) tek anahtar:
API_KEY=
# true: anahtar yoksa veri uclari 503 (fail-safe):
AUTH_REQUIRED=true
# true: auth + anahtar yoksa servis baslamaz:
PRODUCTION_MODE=false
# /demo canli test sayfasi (uretimde kapali):
DEMO_ENABLED=false
# false: /metrics de API key ister:
METRICS_PUBLIC=false
# Guvenli varsayilan: bos (same-origin only). Panel/dashboard nginx reverse-proxy
# ile ayni-origin gittigi icin (bkz. deploy/panel) bu varsayilandan ETKILENMEZ.
# Cross-origin bir tarayici istemciniz varsa acikca izin verin, orn:
# CORS_ORIGINS=https://ornek-dashboard.com
CORS_ORIGINS=
# IP veya API key basina istek limiti:
RATE_LIMIT=120/minute
RATE_LIMIT_ENABLED=true
MAX_SYMBOLS_PER_REQUEST=100 # /quotes ve /validate icin sembol sayisi ust siniri

# === SSE ===
STREAM_INTERVAL=5           # (gelecek poll fallback icin ayrildi)
MAX_SSE_CLIENTS=200         # es zamanli SSE baglanti ust siniri (DoS korumasi)

# === Webhook (olay bazli alarmlar) ===
WEBHOOKS_ENABLED=false
WEBHOOKS_CONFIG=webhooks.json
WEBHOOK_TIMEOUT=5.0
WEBHOOK_MAX_RETRIES=3
# Bos ise yalnizca https zorunlu; dolu ise hostname allowlist (virgulle).
WEBHOOK_URL_ALLOWLIST=

# === Persistence (intraday snapshot) ===
PERSISTENCE_ENABLED=true
PERSISTENCE_MAX_POINTS=500  # sembol basina saklanacak son nokta sayisi

# === Loglama ===
LOG_LEVEL=INFO
LOG_JSON=true

# === Telegram bot (ayri surec; REST API istemcisi) ===
# Bot mevcut REST API'yi tuketir; python-telegram-bot kullanmaz (ham httpx).
# TELEGRAM_ENABLED=false VEYA token bos ise bot idle/temiz cikar (crash yok).
# NOT: env-file'da satir-ici yorum riskli (bazi loader'lar degere katar); yorumlar
# ayri satirda tutuldu.
TELEGRAM_ENABLED=false
# BotFather token'i (orn. 123456:AA...). ASLA repoya commit etmeyin (.env git-ignored).
TELEGRAM_BOT_TOKEN=
# BIST API taban adresi (compose agi icinde):
TELEGRAM_API_URL=http://api:8000
# BIST API auth aciksa gonderilecek X-API-Key (bos ise eklenmez):
TELEGRAM_API_KEY=
# getUpdates long-poll zaman asimi (sn):
TELEGRAM_POLL_TIMEOUT=30
# Virgulle chat id listesi; bos ise herkes /start edebilir:
TELEGRAM_ALLOWED_CHATS=
# Piyasa acilis/kapanis gecis kontrol araligi (sn):
TELEGRAM_MARKET_POLL_SECONDS=30
